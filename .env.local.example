# Local development environment (Supabase CLI).
# Copy to .env.local:  cp .env.local.example .env.local
#
# These are the standard, non-secret defaults printed by `npm run db:start` /
# `npm run db:status`. The local CLI stack still prints a legacy JWT-format
# key; it works as-is in the publishable key slot. If your local key differs,
# paste it in below.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
NEXT_PUBLIC_ADMIN_EMAIL=gilberthl93@gmail.com

# Optional — only needed to test Google sign-in against the LOCAL Supabase
# stack. Leave blank to use magic-link sign-in locally (links land in Inbucket
# at http://127.0.0.1:54324). To enable, create OAuth credentials in the Google
# Cloud console with redirect URI http://127.0.0.1:54321/auth/v1/callback, fill
# these in, and set `enabled = true` under [auth.external.google] in
# supabase/config.toml.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
